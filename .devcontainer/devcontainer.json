{
    "name": "Flutter Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "args": { "USER_UID": "1000", "USER_GID": "1000" }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "dart-code.flutter",
                "dart-code.dart-code"
            ]
        }
    },
    "remoteUser": "dev",
    "mounts": [
        // This allows the container to see your phone via USB
        "source=/dev/bus/usb,target=/dev/bus/usb,type=bind"
    ],
    "runArgs": [
        "--privileged"
    ]
}
